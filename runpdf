#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT_DIR"

source "$ROOT_DIR/.runlib.sh"

usage() {
  cat <<'EOF'
Usage:
  ./runpdf "input/pdf/mon-livre.pdf" [options]
  ./runpdf --dry-run
  ./runpdf --setup-engines
  ./runpdf --engines-status

Examples:
  ./runpdf "input/pdf/mon-livre.pdf"
  ./runpdf "input/pdf/mon-livre.pdf" --engine smart --overwrite
  ./runpdf "input/pdf/mon-livre.pdf" --engine ocrmypdf --ocr-language fra
  ./runpdf "input/pdf/mon-livre.pdf" --max-pages 10 --overwrite
  ./runpdf --setup-engines
  ./runpdf --setup-engines --download-mineru-models

If input/pdf/ contains exactly one PDF, ./runpdf can be launched without a file.
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--engines-status" ]]; then
  echo "PDF engine status:"
  print_pdf_engine_status
  exit 0
fi

if [[ "${1:-}" == "--setup-engines" ]]; then
  DOWNLOAD_MINERU_MODELS="false"
  if [[ "${2:-}" == "--download-mineru-models" ]]; then
    DOWNLOAD_MINERU_MODELS="true"
  fi
  install_pdf_engines "$DOWNLOAD_MINERU_MODELS"
  exit 0
fi

if [[ $# -eq 0 || "${1:-}" == "--dry-run" ]]; then
  PDF_FILES=()
  while IFS= read -r pdf_file; do
    PDF_FILES+=("$pdf_file")
  done < <(find input/pdf -maxdepth 1 -type f -name "*.pdf" | sort)
  if [[ ${#PDF_FILES[@]} -eq 0 ]]; then
    usage
    echo
    echo "No PDF found in input/pdf/."
    exit 1
  fi
  if [[ ${#PDF_FILES[@]} -gt 1 ]]; then
    usage
    echo
    echo "Several PDFs found. Choose one:"
    printf '  %s\n' "${PDF_FILES[@]}"
    exit 1
  fi
  if [[ $# -eq 0 ]]; then
    set -- "${PDF_FILES[0]}"
  else
    set -- "${PDF_FILES[0]}" "$@"
  fi
fi

ensure_runtime
if [[ "${1:-}" != "--dry-run" ]]; then
  offer_pdf_engine_install "${1:-}"
fi
ensure_env_file
activate_pdf_engine_bins

exec "$PYTHON_BIN" -m src.cli run-pdf "$@"
