# AI provider: auto detects the first non-empty key. Or force gemini,
# openai_compatible or anthropic explicitly.
# OpenAI-compatible also covers OpenAI, Mistral, OpenRouter, Ollama, LM Studio and vLLM.
LLM_PROVIDER=auto

# Fill only the provider you want to use. Leave all other keys empty.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
LLM_API_KEY=

# Required only for a custom OpenAI-compatible endpoint.
# LLM_BASE_URL=https://api.openai.com/v1

GEMINI_VIDEO_MODEL=gemini-3.1-flash-lite
GEMINI_VIDEO_DENSE_MODEL=gemini-2.5-flash-lite
GEMINI_PDF_MODEL=gemini-2.5-flash
GEMINI_PDF_CHUNK_MODEL=gemini-2.5-flash-lite

# Optional provider-specific model names. The YAML defaults remain Gemini.
# LLM_MODEL_VIDEO_SIMPLE=gpt-4o-mini
# LLM_MODEL_VIDEO_DENSE=gpt-4o-mini
# LLM_MODEL_PDF_DEEP=gpt-4o
# LLM_MODEL_PDF_CHUNK=gpt-4o-mini
# LLM_MODEL_PDF_FINAL_SYNTHESIS=gpt-4o
# LLM_MODEL_PDF_VISUAL_VERIFIER=gpt-4o

MAX_SINGLE_REQUEST_TOKENS=160000
MAX_VIDEO_OUTPUT_TOKENS=8000
MAX_PDF_OUTPUT_TOKENS=32000

KEEP_OUTPUT_ASK=true
KEEP_CACHE=false
DELETE_INPUT_AFTER_RUN=false
