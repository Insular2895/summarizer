# Cookies YouTube (privé - ne jamais commiter)
.env
cookies.txt

# Fichiers macOS
.DS_Store

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Transcripts téléchargés (output du script, pas du code)
playlists/
[0-9]*/

# Logs et métadonnées yt-dlp
*.log
*.tsv

# Pipeline local
cache/
input/pdf/*
input/youtube/urls.txt

output/videos/*
output/books/*
output/graphipy_ready/*

*.srt
*.vtt
*.txt
*.pdf

!input/pdf/.gitkeep
!input/youtube/urls.example.txt
!output/videos/.gitkeep
!output/books/.gitkeep
!output/graphipy_ready/.gitkeep
!requirements.txt
!requirements-dev.txt
!requirements-pdf.txt
!tests/fixtures/*.txt
!tests/fixtures/*.srt
!tests/fixtures/*.vtt
