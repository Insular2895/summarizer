# Cookies YouTube (privé - ne jamais commiter)
.env
cookies.txt

# Fichiers macOS
.DS_Store

# Python
__pycache__/
*.pyc
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv*/
.engine-bin/

# Transcripts téléchargés (output du script, pas du code)
playlists/
[0-9]*/

# Logs et métadonnées yt-dlp
*.log
*.tsv

# Pipeline local
cache/
library/*
!library/youtube/
library/youtube/*
!library/youtube/*/
library/youtube/*/*
!library/youtube/*/transcript.txt
!library/youtube/*/metadata.json
input/pdf/*
input/youtube/urls.txt

output/videos/*
output/books/*
output/graphipy_ready/*
output/motion/*

*.srt
*.vtt
*.txt
*.pdf

!input/pdf/.gitkeep
!input/youtube/urls.example.txt
!output/videos/.gitkeep
!output/books/.gitkeep
!output/graphipy_ready/.gitkeep
!output/motion/.gitkeep
!requirements.txt
!requirements-dev.txt
!requirements-pdf.txt
!requirements-pdf-ocrmypdf.txt
!requirements-pdf-mineru.txt
!requirements-pdf-marker.txt
!tests/fixtures/*.txt
!tests/fixtures/*.srt
!tests/fixtures/*.vtt
!library/youtube/*/transcript.txt
!library/youtube/*/metadata.json
